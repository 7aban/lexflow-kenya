# LexFlow Kenya server environment
# Copy this file to server/.env or set these variables in your hosting environment.

# REQUIRED in production: Use a long random string (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (default: 5000)
PORT=5000

# CORS allowed origins (comma-separated, no spaces)
# Examples:
#   Single: CORS_ORIGINS=https://lexflow.co.ke
#   Multiple: CORS_ORIGINS=https://lexflow.co.ke,https://app.lexflow.co.ke
# Development default: allows localhost:5173, localhost:5174
CORS_ORIGINS=

# Database path (default: lawfirm.db in project root)
DATABASE_PATH=

# Backup directory (default: ../backups from server/)
BACKUP_DIR=

# Backup log path (default: ../logs/backup.log from server/)
BACKUP_LOG=

# Base URL for invitations/reminders (default: http://localhost:5000 in dev)
BASE_URL=

# Seed admin configuration (for first-time setup)
# REQUIRED in production if no admin exists
SEED_ADMIN_EMAIL=admin@lexflow.co.ke
SEED_ADMIN_PASSWORD=change-this-to-a-strong-password-12plus-chars
SEED_ADMIN_NAME=Admin

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# JSON body limit (default: 1mb)
JSON_BODY_LIMIT=1mb

# Upload body limit (default: 10mb)
UPLOAD_BODY_LIMIT=10mb

# Helmet CSP (set to 'true' for report-only mode)
CSP_REPORT_ONLY=false
# CSP directives as JSON (optional, uses defaults if not set)
# CSP_DIRECTIVES={"defaultSrc":["'self'"],"scriptSrc":["'self'"]}

# Set to 'production' in production
NODE_ENV=development
