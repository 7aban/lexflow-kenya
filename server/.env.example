# LexFlow Kenya server environment
# Copy this file to server/.env or set these variables in your hosting environment.

# REQUIRED in production: Use a long random string (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (default: 5000)
PORT=5000

# CORS allowed origins (comma-separated, no spaces)
# Examples:
#   Single: CORS_ORIGINS=https://lexflow.co.ke
#   Multiple: CORS_ORIGINS=https://lexflow.co.ke,https://app.lexflow.co.ke
# Development default: allows localhost:5173, localhost:5174
CORS_ORIGINS=

# Database path (default: lawfirm.db in project root)
DATABASE_PATH=

# Backup directory (default: ../backups from server/)
BACKUP_DIR=

# Backup log path (default: ../logs/backup.log from server/)
BACKUP_LOG=

# Base URL for invitations/reminders (default: http://localhost:5000 in dev)
BASE_URL=

# Set to 'production' in production
NODE_ENV=development
